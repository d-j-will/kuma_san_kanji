<!DOCTYPE html>
<html
  lang="en"
  class="[scrollbar-gutter:stable]"
  data-theme={(assigns[:current_user] && assigns[:current_user].theme) || "cupcake"}
>
  <head>
    <meta charset="utf-8" />
    <%= if KumaSanKanjiWeb.FeatureFlagHelper.mobile_ux_enabled?() do %>
      <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <% else %>
      <meta name="viewport" content="width=device-width, initial-scale=1" />
    <% end %>
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="KumaSanKanji" suffix=" · Kuma-san Kanji">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>

  <%= if KumaSanKanjiWeb.FeatureFlagHelper.mobile_ux_enabled?() do %>
    <body
      class="wabi-container mobile-app-shell"
      style="height: 100dvh; display: grid; grid-template-rows: auto 1fr auto;"
    >
      {@inner_content}
      <div class="hidden md:block">
        <KumaSanKanjiWeb.Components.Footer.footer />
      </div>
    </body>
  <% else %>
    <body class="wabi-container min-h-screen flex flex-col pb-32">
      <div class="flex-1 flex flex-col">
        {@inner_content}
      </div>
      <KumaSanKanjiWeb.Components.Footer.footer />
    </body>
  <% end %>
</html>
