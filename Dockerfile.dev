# Development Dockerfile for Docker Compose
# Optimized for development workflow with live reload and debugging capabilities
FROM hexpm/elixir:1.18.3-erlang-27.3-debian-bullseye-20250317-slim

# Install system dependencies for development
# Use --no-install-recommends to reduce image size
RUN apt-get update -y && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    inotify-tools \
    postgresql-client \
    vim \
    nano \
    htop \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Set working directory
WORKDIR /app

# Install hex and rebar
RUN mix local.hex --force && \
    mix local.rebar --force

# Set development environment
ENV MIX_ENV=dev
ENV PHX_SERVER=true

# Copy dependency files first for better layer caching
COPY mix.exs mix.lock ./

# Install mix dependencies with cache mount for better performance
RUN --mount=type=cache,target=/root/.hex \
    --mount=type=cache,target=/root/.mix \
    mix deps.get

# Copy configuration files
COPY config config

# Compile dependencies with cache mount
RUN --mount=type=cache,target=/root/.hex \
    --mount=type=cache,target=/root/.mix \
    mix deps.compile

# Setup assets (install esbuild and tailwind)
RUN mix assets.setup

# Copy assets directory
COPY assets assets

# Build assets for development (not deploy, which is for production)
RUN mix assets.build

# Copy source files
COPY lib lib
COPY priv priv

# Compile application
RUN mix compile

# Create directory for development database files (if needed for SQLite fallback)
RUN mkdir -p /app/db

# Expose Phoenix port
EXPOSE 4000

# Development command with live reload
CMD ["mix", "phx.server"]
